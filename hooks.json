{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event SessionStart",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event UserPromptSubmit",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event PreToolUse",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event PostToolUse",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event Stop",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event SubagentStop",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SLIME_HARNESS=codex node ./scripts/dispatch.js --harness codex --event PreCompact",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
