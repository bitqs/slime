{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2022"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.js", "core/**/*.js", "public/sequencer.js"],
  "exclude": ["public/arena.js", "public/vendor", "node_modules", "demo"]
}
